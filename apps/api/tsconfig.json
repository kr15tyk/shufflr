{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@shufflr/config/tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true
  },
  "include": ["src", "test"],
  "exclude": ["node_modules", "dist"]
}
