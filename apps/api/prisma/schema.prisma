// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  PLAYER
}

enum SeasonStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum MatchStatus {
  SCHEDULED
  COMPLETED
  FORFEITED
  POSTPONED
}

enum DivisionFormat {
  TEAMS
  SINGLES
}

enum ResultStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ResultSource {
  PLAYER
  ADMIN
}

// ──────────────────────────────────────────────
// Models
// ──────────────────────────────────────────────

model Organization {
  id           String   @id @default(uuid())
  name         String
  subdomain    String   @unique
  logoUrl      String?
  primaryColor String?
  contactEmail String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users         User[]
  leagues       League[]
  teams         Team[]
  courts        Court[]
  themeSettings ThemeSettings?
}

model ThemeSettings {
  id             String   @id @default(uuid())
  organizationId String   @unique
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String
  secondaryColor String
  surfaceColor   String?
  textColor      String?
  fontHeading    String?
  fontBody       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model User {
  id             String   @id @default(uuid())
  email          String
  passwordHash   String
  name           String
  role           UserRole @default(PLAYER)
  organizationId String
  createdAt      DateTime @default(now())

  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  players          Player[]
  submittedResults MatchResult[]  @relation("SubmittedResults")
  approvedResults  MatchResult[]  @relation("ApprovedResults")
  notifications    Notification[]

  @@unique([email, organizationId])
  @@index([organizationId])
}

model League {
  id             String   @id @default(uuid())
  name           String
  organizationId String
  format         String
  scoringRules   Json
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  seasons      Season[]

  @@index([organizationId])
}

model Season {
  id        String       @id @default(uuid())
  leagueId  String
  startDate DateTime
  endDate   DateTime
  status    SeasonStatus @default(DRAFT)

  league    League     @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  teams     Team[]
  players   Player[]
  matches   Match[]
  divisions Division[]

  @@index([leagueId])
}

model Division {
  id         String         @id @default(uuid())
  seasonId   String
  name       String
  slug       String
  format     DivisionFormat
  maxTeams   Int?
  archivedAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  season  Season  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  teams   Team[]
  matches Match[]

  @@unique([id, seasonId])
  @@unique([seasonId, slug])
  @@index([seasonId, name])
}

model Team {
  id             String @id @default(uuid())
  name           String
  seasonId       String
  organizationId String
  divisionId     String

  season       Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  division     Division     @relation(fields: [divisionId, seasonId], references: [id, seasonId])
  players      Player[]
  matchesAsA   Match[]      @relation("TeamA")
  matchesAsB   Match[]      @relation("TeamB")

  @@unique([id, seasonId])
  @@index([seasonId])
  @@index([organizationId])
}

model Player {
  id       String @id @default(uuid())
  userId   String
  teamId   String
  seasonId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
  @@index([teamId])
  @@index([seasonId])
}

model Court {
  id             String  @id @default(uuid())
  organizationId String
  name           String
  surfaceType    String
  isActive       Boolean @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  matches      Match[]

  @@index([organizationId])
}

model Match {
  id          String      @id @default(uuid())
  seasonId    String
  divisionId  String
  teamAId     String
  teamBId     String
  courtId     String
  scheduledAt DateTime
  status      MatchStatus @default(SCHEDULED)

  season   Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  division Division     @relation(fields: [divisionId, seasonId], references: [id, seasonId])
  teamA    Team         @relation("TeamA", fields: [teamAId, seasonId], references: [id, seasonId])
  teamB    Team         @relation("TeamB", fields: [teamBId, seasonId], references: [id, seasonId])
  court    Court        @relation(fields: [courtId], references: [id])
  result   MatchResult?

  @@index([seasonId])
  @@index([divisionId])
  @@index([teamAId, seasonId])
  @@index([teamBId, seasonId])
  @@index([courtId])
}

model MatchResult {
  id              String        @id @default(uuid())
  matchId         String        @unique
  scoreA          Int
  scoreB          Int
  status          ResultStatus  @default(PENDING)
  source          ResultSource  @default(PLAYER)
  rejectionReason String?
  submittedById   String
  approvedById    String?
  rejectedById    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  match       Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  submittedBy User  @relation("SubmittedResults", fields: [submittedById], references: [id])
  approvedBy  User? @relation("ApprovedResults", fields: [approvedById], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
