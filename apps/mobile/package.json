{
  "name": "@shufflr/mobile",
  "version": "0.0.0",
  "private": true,
  "description": "Shufflr React Native + Expo mobile application",
  "main": "expo-router/entry",
  "scripts": {
    "build": "expo export --platform all",
    "dev": "expo start",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "jest --passWithNoTests",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "clean": "rm -rf .expo dist"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.3",
    "@shufflr/types": "*",
    "@shufflr/utils": "*",
    "expo": "~51.0.32",
    "expo-router": "~3.5.23",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-native": "0.74.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@shufflr/config": "*",
    "@testing-library/react-native": "^12.7.2",
    "@types/react": "^18.3.11",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^8.11.0",
    "@typescript-eslint/parser": "^8.11.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.4",
    "typescript": "^5.6.3"
  },
  "jest": {
    "preset": "jest-expo"
  }
}
