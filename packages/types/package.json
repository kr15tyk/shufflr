{
  "name": "@shufflr/types",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript types and interfaces for the Shufflr monorepo",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "lint": "eslint src --ext .ts",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@shufflr/config": "*",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
