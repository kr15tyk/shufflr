{
  "name": "@shufflr/utils",
  "version": "0.0.0",
  "private": true,
  "description": "Shared utility functions for the Shufflr monorepo",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@shufflr/types": "*"
  },
  "devDependencies": {
    "@shufflr/config": "*",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"]
  }
}
